# Demo pack environment — copy to `.env` in this pack dir and fill in.
#
#   cp examples/demo/.env.example examples/demo/.env
#
# uipilot reads `<pack>/.env` (here: examples/demo/.env) and uses each KEY as a
# DEFAULT for env-bound values in the pack — `{ from: env, name: KEY }` tokens
# and each app's `base_url { env: KEY }`. A real shell variable of the same name
# overrides the file. `.env` is git-ignored, so real values never get committed.

# --- base URLs (data/<app>.app.yaml → app.base_url.env) ---
CONSOLE_UI_URL=http://127.0.0.1:4001
PORTAL_UI_URL=http://127.0.0.1:4002

# --- token expansions (flowmap.config.yaml → tokens) ---
# Namespaces created entities, e.g. "demo-project-1".
TEST_ENTITY_PREFIX=demo
# Console login email — feeds the `console_email` token, which the sign-in
# action's `email` param defaults to. Set it here to sign in as a real user.
CONSOLE_EMAIL=ops@demo.test

# --- secrets are NOT read from here ---
# The sign-in `password` (and the MFA code) are `secret` params: uipilot never
# bakes a secret into an emitted script from config. Supply the password
# explicitly when compiling, e.g. (having exported it into your shell):
#
#   uipilot script --flow console_sign_in --set password="$CONSOLE_PASSWORD"
#
# CONSOLE_PASSWORD=change-me
